source "https://rubygems.org"

# Local preview stack (Ruby 4 compatible). GitHub Pages builds the live site
# with its own Jekyll; this just needs to reproduce permalinks + redirects,
# which behave identically here.
gem "jekyll", "~> 4.3"
gem "jekyll-redirect-from", "~> 0.16"

# stdlib gems no longer bundled by default in modern Ruby
gem "webrick"
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
